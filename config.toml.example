# Callen Configuration
# Copy this file to config.toml and fill in your credentials.
# config.toml is gitignored — it will NOT be committed.

[sip]
registrar = "sip:seattle1.voip.ms"  # Use your DID's POP server, NOT sip.voip.ms
username = "YOUR_VOIPMS_ACCOUNT_NUMBER"  # Found in portal: Main Account > Account Settings (NOT the DID number)
password = "YOUR_VOIPMS_SIP_PASSWORD_HERE"
domain = "seattle1.voip.ms"  # Must match the registrar server
port = 5060

[operator]
name = "David"
cell_phone = "+15031234567"
default_status = "available"  # "available", "busy", "dnd"

[recording]
enabled = true
directory = "./calls"
split_channels = true

[voicemail]
directory = "./voicemail"
max_duration = 120  # seconds

[transcription]
enabled = true
model = "nvidia/parakeet-tdt-0.6b-v2"
device = "auto"  # "auto", "cuda:0", "cpu"
chunk_seconds = 3.0

[tts]
# Text-to-speech engine used for IVR prompts.
# "kokoro" (default) — neural, high quality, loads ~82M params on startup
# "espeak"           — fast, low quality, no model required
engine = "kokoro"
voice = "af_heart"   # kokoro: voice id; espeak: voice name
lang_code = "a"      # kokoro lang: 'a' = American English, 'b' = British
device = ""          # "", "cpu", or "cuda"

[preflight]
# Local-LLM email classifier — a defense-in-depth layer that runs a
# small model via Ollama to screen every inbound email BEFORE it ever
# reaches the Claude Code agent. Catches prompt injection, marketing,
# and automated mail that a regex scanner might miss.
#
# Requires Ollama running locally and the chosen model pulled:
#   ollama pull mistral:7b
enabled = true
provider = "ollama"
url = "http://localhost:11434"
model = "mistral:7b"
timeout = 30.0

[web]
host = "127.0.0.1"
port = 8080

[email]
enabled = true

# --- Outbound SMTP (voicemail notify, auto-replies, agent replies) ---
smtp_host = "smtp.example.com"
smtp_port = 587
smtp_user = "hello@freesoftware.support"
smtp_password = "YOUR_SMTP_PASSWORD_HERE"
smtp_tls = true
from_address = "hello@freesoftware.support"
to_address = "david@freesoftware.support"   # where voicemail notifications go

# --- Inbound IMAP (poll hello@ for new support requests) ---
imap_enabled = true
imap_host = "imap.example.com"
imap_port = 993
imap_ssl = true
# imap_user / imap_password default to the SMTP credentials above if blank
imap_user = ""
imap_password = ""
imap_mailbox = "INBOX"
imap_poll_seconds = 30
hello_address = "hello@freesoftware.support"  # the monitored mailbox address
auto_reply_consent = true  # send a consent request on first contact from a new sender

[general]
db_path = "./callen.db"
ivr_script = "./IVR.py"
log_level = "INFO"
